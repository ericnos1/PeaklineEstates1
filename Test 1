.steps-v::before{content:'';position:absolute;left:39px;top:0;bottom:0;width:1px;background:linear-gradient(to bottom,var(--gold),rgba(201,168,76,0.1));}
.step-row{display:flex;gap:40px;margin-bottom:52px;align-items:flex-start;}
.step-row:last-child{margin-bottom:0;}
.step-num-box{width:80px;height:80px;flex-shrink:0;border:1.5px solid var(--gold);background:var(--white);display:flex;align-items:center;justify-content:center;position:relative;z-index:1;transition:var(--tr);}
.step-num-box:hover{background:var(--gold-pale);}
.step-num{font-family:var(--font-display);font-size:28px;color:var(--navy);font-weight:300;}
.step-body{padding-top:18px;}
.step-title{font-family:var(--font-display);font-size:24px;color:var(--navy);font-weight:400;margin-bottom:8px;}
.step-desc{font-size:14px;color:var(--gray-600);line-height:1.8;font-weight:300;max-width:560px;}
.step-tag{display:inline-block;margin-top:12px;background:var(--gold-pale);color:var(--gray-600);font-size:11px;letter-spacing:0.1em;padding:4px 12px;font-weight:500;text-transform:uppercase;}
/* LANDLORD / TENANT SPLIT */
.split-section{display:grid;grid-template-columns:1fr 1fr;gap:0;}
.split-pane{padding:80px;}
.split-pane.dark{background:var(--navy);}
.split-pane.light{background:var(--white);}
.split-title{font-family:var(--font-display);font-size:32px;font-weight:300;margin-bottom:24px;line-height:1.15;}
.split-pane.dark .split-title{color:var(--white);}
.split-pane.light .split-title{color:var(--navy);}
.split-list{list-style:none;}
.split-list li{padding:12px 0;border-bottom:1px solid;font-size:14px;display:flex;gap:12px;align-items:flex-start;line-height:1.5;font-weight:300;}
.split-pane.dark .split-list li{border-bottom-color:rgba(255,255,255,0.07);color:rgba(255,255,255,0.65);}
.split-pane.light .split-list li{border-bottom-color:var(--gray-100);color:var(--gray-600);}
.split-tick-gold{color:var(--gold);flex-shrink:0;}
/* TESTIMONIALS */
.testi-grid{display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:56px;}
.testi-card{background:var(--white);border:1px solid var(--gray-200);padding:36px;position:relative;transition:var(--tr);}
.testi-card:hover{border-color:rgba(201,168,76,0.5);}
.testi-accent{position:absolute;top:0;left:0;right:0;height:3px;background:var(--gold);}
.testi-quote{font-family:var(--font-display);font-size:64px;color:var(--gold);line-height:0.5;margin-bottom:16px;opacity:0.4;font-weight:300;}
.testi-text{font-family:var(--font-display);font-style:italic;font-size:17px;color:var(--navy);line-height:1.7;margin-bottom:20px;font-weight:300;}
.testi-stars{color:var(--gold);font-size:12px;letter-spacing:4px;margin-bottom:16px;}
.testi-author{display:flex;align-items:center;gap:12px;}
.testi-av{width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:500;color:var(--white);flex-shrink:0;}
.testi-name{font-size:14px;color:var(--navy);font-weight:500;}
.testi-role{font-size:12px;color:var(--gray-400);}
/* CONTACT */
.contact-grid{display:grid;grid-template-columns:1fr 1.4fr;gap:80px;align-items:start;}
.ci-block{margin-bottom:32px;}
.ci-label{font-size:10px;letter-spacing:0.2em;text-transform:uppercase;color:var(--gold);font-weight:500;margin-bottom:8px;}
.ci-value{font-family:var(--font-display);font-size:18px;color:var(--navy);font-weight:300;line-height:1.5;}
.ci-value a{color:var(--navy);text-decoration:none;transition:var(--tr);}
.ci-value a:hover{color:var(--gold);}
.form-box{background:var(--cream);padding:48px;}
.form-box-title{font-family:var(--font-display);font-size:26px;color:var(--navy);font-weight:400;margin-bottom:28px;}
.fg{margin-bottom:16px;}
.fg label{display:block;font-size:10px;letter-spacing:0.16em;text-transform:uppercase;color:var(--gray-600);margin-bottom:7px;font-weight:500;}
.fg input,.fg select,.fg textarea{width:100%;border:1px solid var(--gray-200);padding:12px 16px;font-size:14px;color:var(--gray-800);font-family:var(--font-body);font-weight:300;background:var(--white);outline:none;transition:var(--tr);-webkit-appearance:none;resize:vertical;}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--gold);}
.fg textarea{min-height:100px;}
.fg-grid{display:grid;grid-template-columns:1fr 1fr;gap:16px;}
.fg-full{grid-column:1/-1;}
/* CTA + FOOTER */
.cta-bottom{background:var(--navy);padding:80px 0;text-align:center;position:relative;overflow:hidden;}
.cta-bottom::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 50% 50%,rgba(201,168,76,0.07) 0%,transparent 65%);}
.cta-bottom h2{font-family:var(--font-display);font-size:clamp(32px,4vw,52px);color:var(--white);font-weight:300;margin-bottom:12px;position:relative;}
.cta-bottom h2 em{font-style:italic;color:var(--gold-light);}
.cta-bottom p{color:rgba(255,255,255,0.5);font-size:15px;font-weight:300;margin-bottom:40px;position:relative;}
footer{background:var(--navy);color:rgba(255,255,255,0.45);padding:56px 0 28px;border-top:1px solid rgba(201,168,76,0.2);}
.footer-top{display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:40px;flex-wrap:wrap;gap:32px;}
.footer-nav{display:flex;gap:48px;flex-wrap:wrap;}
