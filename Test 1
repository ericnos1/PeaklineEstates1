.fnc-links a{color:rgba(255,255,255,0.4);text-decoration:none;font-size:13px;font-weight:300;transition:var(--tr);}
.fnc-links a:hover{color:var(--gold-light);}
.footer-bar{display:flex;justify-content:space-between;align-items:center;padding-top:24px;border-top:1px solid rgba(255,255,255,0.07);font-size:12px;color:rgba(255,255,255,0.25);flex-wrap:wrap;gap:16px;}
.footer-bar a{color:rgba(255,255,255,0.25);text-decoration:none;transition:var(--tr);}
.footer-bar a:hover{color:rgba(201,168,76,0.7);}
.footer-bar-links{display:flex;gap:24px;}
.fi{opacity:0;transform:translateY(20px);transition:opacity 0.6s ease,transform 0.6s ease;}
.fi.vis{opacity:1;transform:none;}
