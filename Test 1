<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Guaranteed Rent Scheme | Peakline Estates – Luton & Milton Keynes</title>
<meta name="description" content="Get guaranteed rent every month — whether your property is occupied or not. Peakline Estates' guaranteed rent scheme covers Luton, Milton Keynes and the surrounding areas.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@300;400;500;600&display=swap" rel="stylesheet">

<style>
  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --navy: #0a1628;
    --navy-mid: #132240;
    --navy-light: #1e3560;
    --gold: #c9a84c;
    --gold-light: #e2c97e;
    --gold-pale: #f5edda;
    --cream: #faf8f3;
    --white: #ffffff;
    --gray-100: #f4f2ed;
    --gray-200: #e8e4db;
    --gray-400: #a09880;
    --gray-600: #6b6358;
    --gray-800: #3a342c;
    --font-display: 'Cormorant Garamond', Georgia, serif;
    --font-body: 'Jost', 'Helvetica Neue', sans-serif;
    --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    --green-ok: #2a7a52;
    --green-ok-pale: #e8f5ef;
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: var(--font-body);
    background: var(--cream);
    color: var(--gray-800);
    line-height: 1.7;
    font-size: 15px;
    font-weight: 300;
  }

  /* ─── TOPBAR ─── */
  .topbar {
    background: var(--navy);
    color: var(--gray-400);
    font-size: 12px;
    letter-spacing: 0.06em;
    padding: 8px 0;
    border-bottom: 1px solid rgba(201,168,76,0.2);
  }
  .topbar-inner {
    max-width: 1280px; margin: 0 auto; padding: 0 32px;
    display: flex; justify-content: space-between; align-items: center;
  }
  .topbar a { color: var(--gray-400); text-decoration: none; transition: var(--transition); }
  .topbar a:hover { color: var(--gold-light); }
  .topbar-links { display: flex; gap: 24px; }

  /* ─── NAV ─── */
  nav {
    background: var(--navy);
    position: sticky; top: 0; z-index: 100;
    box-shadow: 0 2px 40px rgba(0,0,0,0.35);
  }
  .nav-inner {
    max-width: 1280px; margin: 0 auto; padding: 0 32px;
    display: flex; align-items: center; justify-content: space-between; height: 76px;
  }
  .logo { display: flex; align-items: center; gap: 14px; text-decoration: none; }
  .logo-mark {
    width: 44px; height: 44px;
    border: 1.5px solid var(--gold);
    display: flex; align-items: center; justify-content: center; position: relative;
  }
  .logo-mark::before {
    content: ''; position: absolute; inset: 3px;
    border: 0.5px solid rgba(201,168,76,0.3);
  }
  .logo-diamond { width: 16px; height: 16px; background: var(--gold); transform: rotate(45deg); }
  .logo-text { line-height: 1.15; }
  .logo-name { font-family: var(--font-display); font-size: 22px; font-weight: 600; color: var(--white); letter-spacing: 0.03em; }
  .logo-sub { font-size: 9px; letter-spacing: 0.22em; color: var(--gold); text-transform: uppercase; }
  .nav-links { display: flex; list-style: none; }
  .nav-links li { position: relative; }
  .nav-links a {
    display: block; padding: 28px 18px;
    color: rgba(255,255,255,0.75); text-decoration: none;
    font-size: 13px; letter-spacing: 0.08em; text-transform: uppercase; font-weight: 400;
    transition: var(--transition); position: relative;
  }
  .nav-links a::after {
    content: ''; position: absolute; bottom: 0; left: 18px; right: 18px;
    height: 2px; background: var(--gold); transform: scaleX(0); transition: var(--transition);
  }
  .nav-links a:hover { color: var(--white); }
  .nav-links a:hover::after { transform: scaleX(1); }
  .nav-links a.active { color: var(--gold); }
  .nav-links a.active::after { transform: scaleX(1); }
  .nav-cta {
    background: var(--gold); color: var(--navy) !important;
    padding: 10px 22px !important; font-weight: 500 !important;
    letter-spacing: 0.1em !important; margin-left: 8px;
  }
  .nav-cta:hover { background: var(--gold-light) !important; }
  .nav-cta::after { display: none !important; }

  /* ─── HERO ─── */
  .gr-hero {
    background: var(--navy);
    min-height: 100vh;
    display: grid;
    grid-template-columns: 1fr 420px;
    position: relative;
    overflow: hidden;
    align-items: stretch;
  }
  .gr-hero-pattern {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(201,168,76,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(201,168,76,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
  }
  .gr-hero-content {
    display: flex; flex-direction: column; justify-content: center;
    padding: 100px 80px 100px 80px;
    position: relative; z-index: 2;
  }
  .hero-badge {
    display: inline-flex; align-items: center; gap: 10px;
    background: rgba(201,168,76,0.12);
    border: 1px solid rgba(201,168,76,0.3);
    padding: 8px 16px;
    margin-bottom: 32px;
    width: fit-content;
  }
  .hero-badge-dot { width: 8px; height: 8px; background: var(--gold); border-radius: 50%; animation: pulse-dot 2s ease-in-out infinite; }
  @keyframes pulse-dot { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:0.5;transform:scale(0.8)} }
  .hero-badge span { font-size: 11px; letter-spacing: 0.18em; text-transform: uppercase; color: var(--gold); font-weight: 500; }
  .gr-hero h1 {
    font-family: var(--font-display);
    font-size: clamp(44px, 5vw, 72px);
    font-weight: 300; color: var(--white);
    line-height: 1.06; margin-bottom: 28px; letter-spacing: -0.01em;
  }
  .gr-hero h1 em { font-style: italic; color: var(--gold-light); font-weight: 300; }
  .gr-hero-desc {
    color: rgba(255,255,255,0.6);
    font-size: 16px; font-weight: 300; max-width: 480px; margin-bottom: 48px; line-height: 1.85;
  }
  .hero-trust-row {
    display: flex; align-items: center; gap: 32px; flex-wrap: wrap;
    margin-bottom: 48px; padding: 20px 0; border-top: 1px solid rgba(255,255,255,0.1);
  }
  .trust-badge { display: flex; align-items: center; gap: 8px; }
  .trust-badge svg { width: 16px; height: 16px; stroke: var(--gold); fill: none; flex-shrink: 0; }
  .trust-badge span { font-size: 12px; color: rgba(255,255,255,0.55); letter-spacing: 0.04em; }
  .hero-cta-row { display: flex; gap: 16px; flex-wrap: wrap; }

  /* ─── STICKY FORM PANEL ─── */
  .gr-form-panel {
    background: var(--white);
    position: sticky; top: 76px;
    height: calc(100vh - 76px);
    overflow-y: auto;
    border-left: 1px solid rgba(201,168,76,0.15);
    display: flex; flex-direction: column;
    z-index: 10;
  }
  .form-panel-header {
    background: var(--gold);
    padding: 28px 32px;
    flex-shrink: 0;
  }
  .form-panel-header h3 {
    font-family: var(--font-display);
    font-size: 22px; font-weight: 500; color: var(--navy);
    margin-bottom: 4px;
  }
  .form-panel-header p { font-size: 13px; color: rgba(10,22,40,0.65); font-weight: 300; }
  .form-panel-body { padding: 28px 32px; flex: 1; }
  .fp-group { margin-bottom: 16px; }
  .fp-group label {
    display: block; font-size: 10px; letter-spacing: 0.16em;
    text-transform: uppercase; color: var(--gray-600); margin-bottom: 6px; font-weight: 500;
  }
  .fp-group input, .fp-group select, .fp-group textarea {
    width: 100%; border: 1px solid var(--gray-200); padding: 11px 14px;
    font-size: 13px; color: var(--gray-800); font-family: var(--font-body);
    font-weight: 300; background: var(--cream); outline: none;
    transition: var(--transition); -webkit-appearance: none; resize: none;
  }
  .fp-group input:focus, .fp-group select:focus, .fp-group textarea:focus { border-color: var(--gold); background: var(--white); }
  .fp-submit {
    background: var(--navy); color: var(--white);
    border: none; width: 100%; padding: 15px;
    font-size: 12px; letter-spacing: 0.14em; text-transform: uppercase;
    font-family: var(--font-body); font-weight: 500; cursor: pointer;
    transition: var(--transition); margin-top: 4px;
  }
  .fp-submit:hover { background: var(--navy-light); }
  .form-privacy {
    font-size: 11px; color: var(--gray-400);
    text-align: center; margin-top: 12px; line-height: 1.6;
  }
  .form-panel-divider { height: 1px; background: var(--gray-200); margin: 20px 0; }
  .form-quick-contact { text-align: center; }
  .form-quick-contact p { font-size: 12px; color: var(--gray-400); margin-bottom: 8px; letter-spacing: 0.06em; }
  .form-phone {
    font-family: var(--font-display); font-size: 20px; color: var(--navy);
    font-weight: 400; text-decoration: none; display: block;
    transition: var(--transition);
  }
  .form-phone:hover { color: var(--gold); }

  /* ─── SECTION COMMONS ─── */
  .container { max-width: 1280px; margin: 0 auto; padding: 0 32px; }
  .section-eyebrow { display: flex; align-items: center; gap: 12px; margin-bottom: 16px; }
  .section-eyebrow-line { width: 32px; height: 1px; background: var(--gold); }
  .section-eyebrow span { font-size: 10px; letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold); font-weight: 500; }
  .section-title { font-family: var(--font-display); font-size: clamp(30px, 3.5vw, 46px); font-weight: 300; color: var(--navy); line-height: 1.15; letter-spacing: -0.01em; }
  .section-title em { font-style: italic; color: var(--gray-600); }

  /* ─── HOW IT WORKS ─── */
  .gr-how { background: var(--white); padding: 96px 0; }
  .steps-timeline { position: relative; margin-top: 64px; }
  .steps-timeline::before {
    content: ''; position: absolute; left: 39px; top: 0; bottom: 0;
    width: 1px; background: linear-gradient(to bottom, var(--gold), rgba(201,168,76,0.1));
  }
  .timeline-step { display: flex; gap: 40px; margin-bottom: 56px; align-items: flex-start; }
  .timeline-step:last-child { margin-bottom: 0; }
  .step-circle {
    width: 80px; height: 80px; flex-shrink: 0;
    border: 1.5px solid var(--gold); background: var(--white);
    display: flex; align-items: center; justify-content: center;
    position: relative; z-index: 1;
    transition: var(--transition);
  }
  .step-circle:hover { background: var(--gold-pale); }
  .step-circle-num {
    font-family: var(--font-display); font-size: 28px; color: var(--navy); font-weight: 300;
  }
  .step-body { padding-top: 18px; }
  .step-title { font-family: var(--font-display); font-size: 24px; color: var(--navy); font-weight: 400; margin-bottom: 10px; }
  .step-desc { font-size: 14px; color: var(--gray-600); line-height: 1.8; font-weight: 300; max-width: 560px; }
  .step-tag {
    display: inline-block; margin-top: 12px;
    background: var(--gold-pale); color: var(--gray-600);
    font-size: 11px; letter-spacing: 0.1em; padding: 4px 12px;
    font-weight: 500; text-transform: uppercase;
  }

  /* ─── WHAT'S INCLUDED ─── */
  .gr-included { background: var(--gray-100); padding: 96px 0; }
  .included-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; background: var(--gray-200); margin-top: 56px; }
  .included-card {
    background: var(--white); padding: 40px 36px;
    transition: var(--transition); position: relative; overflow: hidden;
  }
  .included-card::before {
    content: ''; position: absolute; left: 0; top: 0; bottom: 0;
    width: 3px; background: var(--gold); transform: scaleY(0);
    transition: var(--transition); transform-origin: top;
  }
  .included-card:hover::before { transform: scaleY(1); }
  .included-card:hover { transform: translateX(4px); }
  .included-icon {
    width: 52px; height: 52px; background: var(--navy);
    display: flex; align-items: center; justify-content: center; margin-bottom: 20px;
    transition: var(--transition);
  }
  .included-card:hover .included-icon { background: var(--gold); }
  .included-icon svg { width: 22px; height: 22px; stroke: var(--gold); fill: none; transition: var(--transition); }
  .included-card:hover .included-icon svg { stroke: var(--navy); }
  .included-title { font-family: var(--font-display); font-size: 20px; color: var(--navy); font-weight: 400; margin-bottom: 10px; }
  .included-desc { font-size: 13.5px; color: var(--gray-600); line-height: 1.75; font-weight: 300; }
  .included-check { color: var(--green-ok); font-size: 11px; letter-spacing: 0.08em; margin-top: 12px; font-weight: 500; }

  /* ─── COMPARISON TABLE ─── */
  .gr-compare { background: var(--white); padding: 96px 0; }
  .compare-table { width: 100%; border-collapse: collapse; margin-top: 56px; }
  .compare-table th {
    padding: 20px 24px; text-align: left;
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase; font-weight: 500;
    border-bottom: 2px solid var(--gray-200);
  }
  .compare-table th:first-child { color: var(--gray-600); width: 35%; }
  .compare-table th.col-standard { color: var(--gray-600); }
  .compare-table th.col-gr {
    color: var(--navy); background: var(--gold-pale);
    border-bottom-color: var(--gold); position: relative;
  }
  .col-gr-badge {
    position: absolute; top: -1px; left: 50%; transform: translateX(-50%);
    background: var(--gold); color: var(--navy);
    font-size: 9px; letter-spacing: 0.14em; padding: 3px 10px; white-space: nowrap;
    font-weight: 600;
  }
  .compare-table td {
    padding: 16px 24px; border-bottom: 1px solid var(--gray-100);
    font-size: 14px; color: var(--gray-800); font-weight: 300;
  }
  .compare-table td.col-gr { background: rgba(245,237,218,0.3); }
  .compare-table tr:hover td { background: var(--gray-100); }
  .compare-table tr:hover td.col-gr { background: var(--gold-pale); }
  .tick { color: var(--green-ok); font-size: 16px; font-weight: 600; }
  .cross { color: #c0392b; font-size: 16px; }
  .compare-row-label { font-weight: 400; color: var(--gray-800); }

  /* ─── NUMBERS ─── */
  .gr-numbers { background: var(--navy); padding: 80px 0; }
  .numbers-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 1px; background: rgba(255,255,255,0.08); }
  .number-cell {
    background: var(--navy); padding: 48px 36px; text-align: center;
    transition: var(--transition);
  }
  .number-cell:hover { background: var(--navy-mid); }
  .number-value {
    font-family: var(--font-display); font-size: 52px; color: var(--gold-light);
    font-weight: 300; line-height: 1; margin-bottom: 10px;
  }
  .number-label { font-size: 11px; letter-spacing: 0.16em; text-transform: uppercase; color: rgba(255,255,255,0.45); }
  .number-sub { font-size: 13px; color: rgba(255,255,255,0.25); margin-top: 6px; font-weight: 300; }

  /* ─── FAQ ─── */
  .gr-faq { background: var(--cream); padding: 96px 0; }
  .faq-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 56px; }
  .faq-item {
    background: var(--white); border: 1px solid var(--gray-200);
    overflow: hidden; transition: var(--transition);
  }
  .faq-item:hover { border-color: var(--gold); }
  .faq-q {
    padding: 22px 24px; cursor: pointer;
    display: flex; justify-content: space-between; align-items: center;
    font-size: 15px; font-weight: 400; color: var(--navy); line-height: 1.4;
    user-select: none;
  }
  .faq-q .faq-icon {
    width: 24px; height: 24px; flex-shrink: 0; margin-left: 16px;
    border: 1px solid var(--gray-200); display: flex; align-items: center; justify-content: center;
    font-size: 14px; color: var(--gold); transition: var(--transition);
  }
  .faq-item.open .faq-q { color: var(--gold); }
  .faq-item.open .faq-q .faq-icon { background: var(--navy); border-color: var(--navy); color: var(--white); transform: rotate(45deg); }
  .faq-a {
    max-height: 0; overflow: hidden; transition: max-height 0.35s ease, padding 0.2s ease;
    font-size: 14px; color: var(--gray-600); font-weight: 300; line-height: 1.8;
    padding: 0 24px;
  }
  .faq-item.open .faq-a { max-height: 300px; padding: 0 24px 22px; }

  /* ─── TESTIMONIALS ─── */
  .gr-testimonials { background: var(--white); padding: 96px 0; }
  .testi-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 24px; margin-top: 56px; }
  .testi-card {
    background: var(--cream); border: 1px solid var(--gray-200); padding: 40px;
    position: relative; transition: var(--transition);
  }
  .testi-card:hover { border-color: rgba(201,168,76,0.5); box-shadow: 0 8px 32px rgba(10,22,40,0.08); }
  .testi-card-accent {
    position: absolute; top: 0; left: 0; right: 0; height: 3px; background: var(--gold);
  }
  .testi-quote-mark {
    font-family: var(--font-display); font-size: 72px; color: var(--gold);
    line-height: 0.6; margin-bottom: 20px; opacity: 0.5; font-weight: 300;
  }
  .testi-text {
    font-family: var(--font-display); font-style: italic; font-size: 18px;
    color: var(--navy); line-height: 1.7; margin-bottom: 24px; font-weight: 300;
  }
  .testi-property {
    background: var(--gold-pale); padding: 10px 14px; margin-bottom: 20px;
    font-size: 12px; color: var(--gray-600); letter-spacing: 0.06em;
  }
  .testi-property strong { color: var(--navy); font-weight: 500; }
  .testi-stars { color: var(--gold); font-size: 12px; letter-spacing: 4px; margin-bottom: 16px; }
  .testi-author { display: flex; align-items: center; gap: 12px; }
  .testi-avatar {
    width: 44px; height: 44px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: 14px; font-weight: 500; color: var(--white); flex-shrink: 0;
  }
  .testi-name { font-size: 14px; color: var(--navy); font-weight: 500; }
  .testi-role { font-size: 12px; color: var(--gray-400); }

  /* ─── ELIGIBILITY ─── */
  .gr-eligibility { background: var(--navy); padding: 96px 0; }
  .eligibility-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 64px; align-items: center; margin-top: 56px; }
  .elig-yes, .elig-no { }
  .elig-heading {
    font-size: 11px; letter-spacing: 0.2em; text-transform: uppercase;
    font-weight: 500; margin-bottom: 20px; display: flex; align-items: center; gap: 10px;
  }
  .elig-heading.yes { color: #5ec898; }
  .elig-heading.no { color: rgba(255,255,255,0.4); }
  .elig-list { list-style: none; }
  .elig-list li {
    padding: 12px 0; border-bottom: 1px solid rgba(255,255,255,0.06);
    font-size: 14px; font-weight: 300; display: flex; align-items: flex-start; gap: 12px; line-height: 1.5;
  }
  .elig-list li.yes { color: rgba(255,255,255,0.75); }
  .elig-list li.no { color: rgba(255,255,255,0.35); }
  .elig-tick { flex-shrink: 0; margin-top: 2px; }
  .elig-cta-box {
    margin-top: 56px; background: rgba(201,168,76,0.1); border: 1px solid rgba(201,168,76,0.25);
    padding: 36px; text-align: center;
  }
  .elig-cta-box p { color: rgba(255,255,255,0.6); font-size: 14px; font-weight: 300; margin-bottom: 20px; }
  .elig-cta-box h3 { font-family: var(--font-display); font-size: 26px; color: var(--white); font-weight: 300; margin-bottom: 8px; }

  /* ─── BOTTOM CTA ─── */
  .gr-bottom-cta {
    background: linear-gradient(135deg, var(--navy) 0%, #0f2448 100%);
    padding: 96px 0;
    text-align: center;
    position: relative; overflow: hidden;
  }
  .gr-bottom-cta::before {
    content: '';
    position: absolute; inset: 0;
    background:
      radial-gradient(ellipse at 30% 50%, rgba(201,168,76,0.08) 0%, transparent 60%),
      radial-gradient(ellipse at 70% 50%, rgba(30,53,96,0.5) 0%, transparent 60%);
  }
  .gr-bottom-cta .container { position: relative; z-index: 1; }
  .gr-bottom-cta h2 { font-family: var(--font-display); font-size: clamp(36px,4vw,58px); color: var(--white); font-weight: 300; margin-bottom: 12px; }
  .gr-bottom-cta h2 em { font-style: italic; color: var(--gold-light); }
  .gr-bottom-cta p { color: rgba(255,255,255,0.55); font-size: 16px; font-weight: 300; margin-bottom: 48px; max-width: 560px; margin-left: auto; margin-right: auto; }
  .cta-actions { display: flex; gap: 16px; justify-content: center; flex-wrap: wrap; }

  /* ─── BUTTONS ─── */
  .btn-primary {
